// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider      = "prisma-client"
  output        = "../app/generated/prisma"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("POSTGRES_URL")
}
// schema.prisma

model User { // The Parent
  id                 String    @id @default(cuid())
  email              String    @unique
  password           String    // Hashed
  parentPin          String?   // 4-digit PIN to protect admin from child dashboard
  stripeId           String?   // For payments
  walletBalance      Int       @default(0) // in cents; 1 magic point = 100 cents = $1.00
  referralCode       String?   @unique     // Family-level code for /magic page
  shippingAddress    String?   // Full address for Christmas delivery
  isChristmasLocked  Boolean   @default(false) // true after Finalize; unlocks Dec 26
  finalizedAt        DateTime? // timestamp of finalization
  children           Child[]
  createdAt          DateTime  @default(now())
}

model Child {
  id             String    @id @default(cuid())
  name           String
  parentId       String
  parent         User      @relation(fields: [parentId], references: [id])
  magicPoints    Float     @default(0) // 1 point = $1.00
  votes          DailyVote[]
  wishlist       Toy[]
  deeds          GoodDeed[]
  
  // Meter logic: (Total Positive Votes / Days since Dec 26)
  lastReset      DateTime  @default(now()) 
}

model Toy {
  id             String    @id @default(cuid())
  name           String
  description    String
  image          String    // Vercel Blob URL
  pointCost      Int       // Equivalent to USD
  children       Child[]
}

model DailyVote {
  id             String    @id @default(cuid())
  date           DateTime  @default(now())
  isPositive     Boolean
  childId        String
  child          Child     @relation(fields: [childId], references: [id])

  @@unique([childId, date])
}

model GoodDeed {
  id             String    @id @default(cuid())
  code           String    @unique // Unique code for the printed card
  description    String?
  neighborNote   String?
  pointsEarned   Int       @default(1)
  isConfirmed    Boolean   @default(false)
  childId        String
  child          Child     @relation(fields: [childId], references: [id])
}

// Idempotency log — stores PaymentIntent IDs that have already been processed
model ProcessedEvent {
  id        String   @id  // Stripe PaymentIntent ID (pi_...)
  createdAt DateTime @default(now())
}